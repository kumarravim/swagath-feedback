# =============================================================================
# Swagath Feedback App - .gitignore
# =============================================================================

# Node modules
node_modules/
package-lock.json
yarn.lock

# IDE and Editor files
.vscode/
.vscode-insiders/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.code-workspace

# IDE settings
.editorconfig
.env.local
.env.*.local

# Local development
local.settings.json
*.user
*.suo
*.suo

# Build outputs
bin/
obj/
dist/
build/

# Azure Functions local runtime
.funcignore
.azure/
*.publishsettings

# Deployment
.deployment
web.config
.env
.env.production
.env.development

# Test coverage
coverage/
*.lcov

# System
.env.system
.vscode/launch.json
.vscode/settings.json

# Dependencies Lock files (use for CI/CD, not local)
package-lock.json
yarn.lock

# Temporary files
*.tmp
*.temp
*.bak
*.backup
*~

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Azure
.azure/

# Sensitive files
secrets.json
appsettings.Production.json
SendGridApiKey.txt
