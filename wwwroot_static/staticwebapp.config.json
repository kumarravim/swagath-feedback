{
  "version": "1.0",
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/images/*",
      "/css/*",
      "/js/*",
      "/lib/*",
      "/api/*",
      "/*.{css,scss,html,js,svg,png,jpg,jpeg,gif,ico,json,xml,txt}"
    ]
  },
  "mimeTypes": {
    ".json": "text/json"
  }
}
